// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - username: string (required)
//   - displayName: string (optional)
//   - photoURL: string (optional)
//   - bio: string (optional)
//   - createdAt: timestamp (required)
//
// Collection: listings
// Document ID: {listingId}
// Fields:
//   - id: string (required)
//   - authorId: string (required)
//   - authorName: string (required)
//   - authorPhoto: string (optional)
//   - title: string (required)
//   - description: string (required)
//   - price: number (required)
//   - type: string (sale/request)
//   - images: list (strings)
//   - likes: list (uids)
//   - commentCount: number
//   - createdAt: timestamp
//
// Collection: chats
// Document ID: {chatId}
// Fields:
//   - id: string
//   - participants: list (uids)
//   - lastMessage: string
//   - lastMessageAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }
    
    function isValidUser(data) {
      return data.get('uid', '') == request.auth.uid &&
             data.get('username', '') is string;
    }

    function isValidListing(data) {
      return data.get('authorId', '') == request.auth.uid &&
             data.get('title', '') is string && 
             data.get('price', -1) >= 0 &&
             data.get('type', '') in ['sale', 'request'];
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && isValidUser(request.resource.data) && 
         request.resource.data.get('status', '') == resource.data.get('status', '') &&
         request.resource.data.get('role', '') == resource.data.get('role', '') &&
         request.resource.data.get('isVerified', false) == resource.data.get('isVerified', false))
      );
    }

    // Listings
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidListing(request.resource.data);
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.authorId == request.auth.uid && isValidListing(request.resource.data) && request.resource.data.get('status', '') == resource.data.get('status', '')) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentCount']))
      );
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.authorId == request.auth.uid);
    }

    // Reports
    match /reports/{reportId} {
      allow read, update: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Comments
    match /listings/{listingId}/comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    // Messages
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
  }
}
